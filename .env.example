# --- MongoDB Connection String ---
# Get this from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
# Create a free cluster, then go to 'Connect' -> 'Connect your application'
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/photography?retryWrites=true&w=majority

# --- Cloudinary Credentials ---
# Get these from your Cloudinary Dashboard (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- JWT Secret for Admin Authentication ---
# Any random long string for signing tokens
JWT_SECRET=super-secret-key-change-this

# --- Admin Credentials (Initial) ---
# Used for the first login to /admin/login
ADMIN_USERNAME=Surya
ADMIN_PASSWORD=Surya@098

# --- App URL ---
# Automatically set in AI Studio, used for CORS and redirects
APP_URL=
